{
    "name": "lustingontrash",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Lusting on Trash guild website",
    "scripts": {
        "dev": "node scripts/dev.mjs",
        "dev:server": "pnpm --filter @lot/api run dev",
        "dev:client": "pnpm --filter @lot/web run dev",
        "build": "pnpm run build:client && pnpm run build:server",
        "build:client": "pnpm --filter @lot/web run build",
        "build:server": "pnpm --filter @lot/api run build",
        "start": "pnpm --filter @lot/api run start",
        "format": "prettier --write \"**/*.{ts,tsx,mjs,json,md}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,mjs,json,md}\"",
        "typecheck": "pnpm --filter @lot/api run typecheck && pnpm --filter @lot/web run typecheck",
        "check": "pnpm run format:check && pnpm run typecheck",
        "db:generate": "pnpm --filter @lot/api run db:generate",
        "db:migrate": "pnpm --filter @lot/api run db:migrate",
        "db:migrate:deploy": "pnpm --filter @lot/api run db:migrate:deploy",
        "db:sync": "pnpm --filter @lot/api run db:sync",
        "prepare": "husky"
    },
    "engines": {
        "node": ">=24"
    },
    "packageManager": "pnpm@10.22.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "@prisma/engines",
            "prisma"
        ]
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "8.58.1",
        "@typescript-eslint/parser": "8.58.1",
        "eslint": "10.2.0",
        "husky": "9.1.7",
        "prettier": "3.8.1"
    }
}
