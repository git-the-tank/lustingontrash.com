{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "ES2024",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2024"],
        "outDir": "./dist/server",
        "rootDir": "./src",
        "declaration": true,
        "sourceMap": true,
        "paths": {
            "@server/*": ["./src/server/*"]
        }
    },
    "include": ["src/server/**/*", "src/generated/**/*", "src/guild.config.ts"]
}
