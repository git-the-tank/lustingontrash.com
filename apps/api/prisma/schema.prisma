generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"

}

datasource db {
    provider = "postgresql"
}

enum Role {
    MEMBER
    ADMIN
}

enum Difficulty {
    NORMAL
    HEROIC
    MYTHIC
}

enum FightCategory {
    PROGRESSION
    FARM
    IGNORED
}

enum ReportState {
    NEW
    LIVE
    FINAL
}

enum EffectiveProgEndSource {
    HEURISTIC
    OVERRIDE
    NONE
}

enum DeathClassification {
    PROG_RELEVANT
    WIPE_COLLAPSE
    POST_WIPE_EXIT
    RESET_ROLE_HOLDOUT
}

enum RawPayloadSource {
    REPORT_SPINE
    MASTER_DATA
    TABLE_DEATHS
    TABLE_DAMAGE_TAKEN
    TABLE_CASTS
    TABLE_INTERRUPTS
    TABLE_DISPELS
    TABLE_SUMMARY
}

model Guild {
    id         String      @id @default(cuid())
    wclId      Int         @unique
    name       String
    server     String
    region     String
    characters   Character[]
    fightConfigs FightConfig[]
    reports      Report[]
    createdAt    DateTime      @default(now()) @db.Timestamptz(3)
    updatedAt    DateTime      @updatedAt @db.Timestamptz(3)

    @@unique([name, server, region])
}

model User {
    id                        String      @id @default(cuid())
    battlenetId               String      @unique
    battletag                 String
    role                      Role        @default(MEMBER)
    guildMembershipVerifiedAt DateTime?   @db.Timestamptz(3)
    lastLoginAt               DateTime    @db.Timestamptz(3)
    characters                Character[]
    sessions                  Session[]
    createdAt                 DateTime    @default(now()) @db.Timestamptz(3)
    updatedAt                 DateTime    @updatedAt @db.Timestamptz(3)
}

model Session {
    id               String   @id @default(cuid())
    userId           String
    user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    refreshTokenHash String
    expiresAt        DateTime @db.Timestamptz(3)
    createdAt        DateTime @default(now()) @db.Timestamptz(3)

    @@index([userId])
    @@index([refreshTokenHash])
}

model Character {
    id         String   @id @default(cuid())
    wowauditId Int      @unique
    name       String
    server     String
    className  String
    role       String
    rank       String
    active     Boolean  @default(true)
    guildId    String
    guild      Guild    @relation(fields: [guildId], references: [id])
    userId     String?
    user       User?    @relation(fields: [userId], references: [id])
    parses            Parse[]
    actors            Actor[]
    playerFightFacts  PlayerFightFact[]
    createdAt         DateTime @default(now()) @db.Timestamptz(3)
    updatedAt  DateTime @updatedAt @db.Timestamptz(3)

    @@unique([name, server])
    @@index([guildId])
    @@index([active])
    @@index([userId])
}

model Parse {
    id            String     @id @default(cuid())
    characterId   String
    character     Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
    encounterId   Int
    difficulty    Difficulty
    metric        String
    bestPercent   Float
    medianPercent Float?
    bestAmount    Float?
    bestSpec      String?
    fastestKillMs Int?
    killCount     Int        @default(0)
    syncedAt      DateTime   @default(now()) @db.Timestamptz(3)
    createdAt     DateTime   @default(now()) @db.Timestamptz(3)
    updatedAt     DateTime   @updatedAt @db.Timestamptz(3)

    @@unique([characterId, encounterId, difficulty])
    @@index([encounterId, difficulty])
}

model FightConfig {
    id          String        @id @default(cuid())
    guildId     String
    guild       Guild         @relation(fields: [guildId], references: [id])
    encounterId Int
    difficulty  Difficulty
    category    FightCategory @default(IGNORED)
    config      Json?
    createdAt   DateTime      @default(now()) @db.Timestamptz(3)
    updatedAt   DateTime      @updatedAt @db.Timestamptz(3)

    @@unique([guildId, encounterId, difficulty])
    @@index([guildId])
}

model Report {
    id              String      @id @default(cuid())
    code            String      @unique
    guildId         String
    guild           Guild       @relation(fields: [guildId], references: [id], onDelete: Restrict)
    title           String?
    zoneId          Int?
    startTime       DateTime    @db.Timestamptz(3)
    endTime         DateTime    @db.Timestamptz(3)
    state           ReportState @default(NEW)
    lastFetchedAt   DateTime?   @db.Timestamptz(3)
    lastFightSeenAt DateTime?   @db.Timestamptz(3)
    finalizedAt     DateTime?   @db.Timestamptz(3)
    fights          Fight[]
    actors          Actor[]
    createdAt       DateTime    @default(now()) @db.Timestamptz(3)
    updatedAt       DateTime    @updatedAt @db.Timestamptz(3)

    @@index([guildId, startTime])
    @@index([state])
}

model Fight {
    id                             String                 @id @default(cuid())
    reportId                       String
    report                         Report                 @relation(fields: [reportId], references: [id], onDelete: Cascade)
    fightId                        Int
    encounterId                    Int
    difficulty                     Difficulty
    name                           String?
    kill                           Boolean                @default(false)
    startTime                      Int
    endTime                        Int
    bossPercentage                 Float?
    fightPercentage                Float?
    phaseTransitions               Json?
    effectiveProgEndMs             Int?
    effectiveProgEndSource         EffectiveProgEndSource @default(NONE)
    effectiveProgEndOverrideBy     String?
    effectiveProgEndOverrideAt     DateTime?              @db.Timestamptz(3)
    effectiveProgEndOverrideVersion Int                   @default(0)
    playerFightFacts               PlayerFightFact[]
    createdAt                      DateTime               @default(now()) @db.Timestamptz(3)
    updatedAt                      DateTime               @updatedAt @db.Timestamptz(3)

    @@unique([reportId, fightId])
    @@index([encounterId, difficulty])
}

model Actor {
    id              String          @id @default(cuid())
    reportId        String
    report          Report          @relation(fields: [reportId], references: [id], onDelete: Cascade)
    actorId         Int
    guid            String
    name            String
    type            String
    subType         String?
    characterId     String?
    character       Character?      @relation(fields: [characterId], references: [id], onDelete: SetNull)
    playerFightFacts PlayerFightFact[]
    createdAt       DateTime        @default(now()) @db.Timestamptz(3)
    updatedAt       DateTime        @updatedAt @db.Timestamptz(3)

    @@unique([reportId, actorId])
    @@index([guid])
    @@index([characterId])
}

model Ability {
    id        String   @id @default(cuid())
    abilityId Int      @unique
    name      String
    icon      String?
    createdAt DateTime @default(now()) @db.Timestamptz(3)
    updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model Npc {
    id        String   @id @default(cuid())
    gameId    Int      @unique
    name      String
    createdAt DateTime @default(now()) @db.Timestamptz(3)
    updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model PlayerFightFact {
    id                           String               @id @default(cuid())
    fightId                      String
    fight                        Fight                @relation(fields: [fightId], references: [id], onDelete: Cascade)
    actorId                      String
    actor                        Actor                @relation(fields: [actorId], references: [id], onDelete: Cascade)
    characterId                  String?
    character                    Character?           @relation(fields: [characterId], references: [id], onDelete: SetNull)
    metricVersion                Int
    timeAliveMs                  Int?
    deathTimeMs                  Int?
    deathAbilityId               Int?
    deathClassification          DeathClassification?
    bossPercentAtDeath           Float?
    diedBeforeFirstPhaseTransition Boolean            @default(false)
    defensiveAvailableAtDeath    Boolean?
    unusedAvailableDefensives    Json?
    damageDone                   BigInt?
    damageTaken                  BigInt?
    avoidableDamageTaken         BigInt?
    createdAt                    DateTime             @default(now()) @db.Timestamptz(3)
    updatedAt                    DateTime             @updatedAt @db.Timestamptz(3)

    @@unique([fightId, actorId, metricVersion])
    @@index([characterId])
}

model RawPayloadCache {
    id          String           @id @default(cuid())
    reportCode  String
    sourceType  RawPayloadSource
    fightId     Int?
    payload     Json
    fetchedAt   DateTime         @default(now()) @db.Timestamptz(3)

    @@index([reportCode, sourceType, fightId])
    @@index([reportCode, fetchedAt])
}
