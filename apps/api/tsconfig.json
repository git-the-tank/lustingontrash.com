{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "target": "ES2024",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2024"],
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "sourceMap": true,
        "paths": {
            "@server/*": ["./src/*"]
        }
    },
    "include": ["src/**/*"]
}
