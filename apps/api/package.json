{
    "name": "@lot/api",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Lusting on Trash API server",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsup src/index.ts --format esm --out-dir dist --sourcemap",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "db:sync": "tsx src/jobs/syncCharacters.ts",
        "db:sync:parses": "tsx src/jobs/syncParses.ts"
    },
    "dependencies": {
        "@fastify/cookie": "11.0.2",
        "@fastify/cors": "11.2.0",
        "@fastify/swagger": "9.7.0",
        "@fastify/swagger-ui": "5.2.5",
        "@lot/shared": "workspace:*",
        "@prisma/adapter-pg": "7.7.0",
        "@prisma/client": "7.7.0",
        "dotenv": "17.4.1",
        "fastify": "5.8.4",
        "graphql": "16.13.2",
        "graphql-request": "7.4.0",
        "jose": "6.2.2",
        "pg": "8.20.0",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@types/node": "25.5.2",
        "@types/pg": "8.20.0",
        "prisma": "7.7.0",
        "tsup": "8.5.1",
        "tsx": "4.21.0",
        "typescript": "6.0.2"
    }
}
