{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "noEmit": true,
        "paths": {
            "@client/*": ["./src/client/*"]
        }
    },
    "include": ["src/client/**/*"]
}
